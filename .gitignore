# ── Personal data (legacy safety net) ───────────────────────────────────────
# Personal content now lives outside this repo at workspace_path in
# .sync-config.yaml. Keep these ignores as a hard stop if data folders are
# accidentally recreated locally.
data/profile/
data/facts/
data/context/
data/jobs/
# Subdirectory contents only — keep READMEs and .gitkeep placeholder files.
resumes/*/
data/projects/*/
# Machine-local config written by bootstrap; contains the source data-folder path.
.sync-config.yaml

# ── LaTeX / Tectonic build artifacts ─────────────────────────────────────────
# (resume.pdf + resume.tex are committed intentionally; only ignore intermediates)
*.aux
*.log
*.out
*.fls
*.fdb_latexmk
*.synctex.gz
*.toc
*.bbl
*.blg
build/

# Tectonic cache (if ever created locally)
.tectonic/

# ── OS / editor cruft ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# Local job-tracker runtime artifacts
tracker-web/.venv/
tracker-web/data/
tracker-web/exports/
tracker-web/__pycache__/
