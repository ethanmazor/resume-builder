# ── Personal data ────────────────────────────────────────────────────────────
# This repo is public. All personal content lives under data/. None of it
# should ever be committed except structural placeholder files.
data/profile/
data/facts/
data/context/
data/jobs/
# Subdirectory contents only — keep READMEs and .gitkeep placeholder files.
data/resumes/*/
data/projects/*/
# Machine-local config written by bootstrap; contains the source data-folder path.
.sync-config.yaml

# ── LaTeX / Tectonic build artifacts ─────────────────────────────────────────
# (resume.pdf + resume.tex are committed intentionally; only ignore intermediates)
*.aux
*.log
*.out
*.fls
*.fdb_latexmk
*.synctex.gz
*.toc
*.bbl
*.blg
build/

# Tectonic cache (if ever created locally)
.tectonic/

# ── OS / editor cruft ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# Local job-tracker runtime artifacts
tracker-web/.venv/
tracker-web/data/
tracker-web/exports/
tracker-web/__pycache__/
